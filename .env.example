# ========================================
# Sorveteria Arthies - Variáveis de Ambiente
# ========================================

# --------------
# MODO DE USO:
# --------------
# Copie este arquivo para .env.local e preencha os valores
# cp .env.example .env.local
# --------------

# --------------
# ESCOLHA DO BANCO
# --------------
# Opção 1: Mock (desenvolvimento rápido sem banco)
# NEXT_PUBLIC_USE_MOCK=true

# Opção 2: PostgreSQL Docker (desenvolvimento local com dados persistidos)
# NEXT_PUBLIC_USE_MOCK=false
# DATABASE_URL=postgresql://postgres:sorvete123@localhost:5432/sorveteria

# Opção 3: Supabase (produção)
# NEXT_PUBLIC_USE_MOCK=false
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon
# SUPABASE_SERVICE_ROLE_KEY=sua-chave-service

# ========================================
# CONFIGURAÇÃO PADRÃO (PostgreSQL Docker)
# ========================================

# Banco de dados
NEXT_PUBLIC_USE_MOCK=false
DATABASE_URL=postgresql://postgres:sorvete123@localhost:5432/sorveteria

# Supabase (opcional - apenas para produção)
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-key
SUPABASE_SERVICE_ROLE_KEY=

# JWT Secret (gere uma nova para produção)
JWT_SECRET=sua-chave-jwt-segura-aqui-mude-em-producao

# ========================================
# VARIÁVEIS OPCIONAIS
# ========================================

# NEXT_PUBLIC_SENHA_TEMPORARIA=admin123
# NODE_ENV=development
# NEXT_PUBLIC_TIPO_ENVIO=fisico