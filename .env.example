# ========================================
# SORVETERIA ARTHIES - VARIÁVEIS DE AMBIENTE
# ========================================
# Estrutura Multi-Ambiente (Dev + Prod)
# ========================================

# --------------
# INSTRUÇÕES:
# --------------
# 1. Este arquivo é o TEMPLATE (.env.example)
# 2. Crie .env.local para desenvolvimento LOCAL
# 3. Para DEPLOY: Configure variáveis no painel do Vercel
# 4. NUNCA comite .env.local ou .env.production
# 5. *_SERVICE_ROLE_KEY, SECRET_KEY = apenas server-side
# --------------

# ========================================
# AMBIENTE
# ========================================
NODE_ENV=development

NEXT_PUBLIC_ENVIRONMENT=development

NEXT_PUBLIC_USE_MOCK=false

# ========================================
# SUPABASE DEV (Desenvolvimento)
# ========================================
NEXT_PUBLIC_SUPABASE_DEV_URL=https://funyxwrzebcexrlsmvqn.supabase.co
NEXT_PUBLIC_SUPABASE_DEV_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

SUPABASE_DEV_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# SUPABASE PROD (Produção - São Paulo)
# ========================================
NEXT_PUBLIC_SUPABASE_PROD_URL=https://vejseyijdkwpxkblmokr.supabase.co
NEXT_PUBLIC_SUPABASE_PROD_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

SUPABASE_PROD_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# CONFIGURAÇÃO ATIVA
# ========================================
NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_DEV_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_DEV_ANON_KEY}

# ========================================
# JWT SECRET
# ========================================
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_use_openssl_rand_base64_32

# ========================================
# SENTRY (Error Tracking)
# ========================================
# Obtenha em: https://sentry.io > Settings > Projects > Sorveteria Arthies > Client Keys
SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/xxxxx
SENTRY_ENABLED=true

# ========================================
# RESEND (Email Transactional)
# ========================================
# Obtenha em: https://resend.com > API Keys
# Para DEV: crie domain .local (gratuito)
# Para PROD: verified domain
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Emails admin (recebem notificações)
EMAIL_ADMIN_DEV=1991lotavio@gmail.com
EMAIL_ADMIN_PROD=199lotavion@gmail.com

# ========================================
# STRIPE (Pagamentos)
# ========================================
# Obtenha em: https://dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Webhook secret (obtenha após criar webhook endpoint)
# ngrok http 3000 para testar localmente
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Price IDs (crie produtos no Stripe Dashboard)
STRIPE_PRICE_PRODUTO=price_xxxxx

# ========================================
# POSTHOG (Analytics)
# ========================================
# Obtenha em: https://app.posthog.com > Settings > Project Settings
# Free tier: 1M eventos/mês
NEXT_PUBLIC_POSTHOG_KEY=phc_tvfhYEynrPhRaARdpPgpjAs36Re5HegWi3HFaGCv2QuD
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phx_xxxxx

# ========================================
# CHECKLY (Uptime Monitoring)
# ========================================
# Obtenha em: https://checklyhq.com > Account > API Keys
CHECKLY_API_KEY=cu_e6ae3627ad784060b300c249427e614d
CHECKLY_ACCOUNT_ID=a7477598-8412-417b-bc96-36b60ac88ebf

# URLs para monitorar
NEXT_PUBLIC_SITE_URL=http://localhost:3000

