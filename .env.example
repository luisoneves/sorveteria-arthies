# ========================================
# SORVETERIA ARTHIES - VARIÁVEIS DE AMBIENTE
# ========================================
# Estrutura Multi-Ambiente (Dev + Prod)
# ========================================

# --------------
# INSTRUÇÕES:
# --------------
# 1. Este arquivo é o TEMPLATE (.env.example)
# 2. Crie .env.local para desenvolvimento LOCAL
# 3. Para DEPLOY: Configure variáveis no painel do Vercel
# 4. NUNCA comite .env.local ou .env.production
# 5. SUPABASE_SERVICE_ROLE_KEY = apenas server-side, JAMAIS exposto ao cliente
# --------------

# ========================================
# AMBIENTE
# ========================================
NODE_ENV=development

# --------------
# MODO DE OPERAÇÃO:
# --------------
# development: Usa mock local (sem banco real)
# staging: Usa Supabase Dev
# production: Usa Supabase Prod

NEXT_PUBLIC_ENVIRONMENT=development

# --------------
# MODO MOCK (desabilitar quando usar Supabase)
# --------------
NEXT_PUBLIC_USE_MOCK=true

# ========================================
# SUPABASE DEV (Desenvolvimento)
# ========================================
# Obtenha em: https://supabase.com/dashboard > Projeto DEV > Settings > API

NEXT_PUBLIC_SUPABASE_DEV_URL=https://SEU_PROJETO_DEV.supabase.co
NEXT_PUBLIC_SUPABASE_DEV_ANON_KEY=eyJhbGc...chave-anon-dev

# ⚠️ SERVER-ONLY - Jamais exponha ao cliente!
SUPABASE_DEV_SERVICE_ROLE_KEY=eyJhbGc...chave-service-dev

# ========================================
# SUPABASE PROD (Produção)
# ========================================
# Obtenha em: https://supabase.com/dashboard > Projeto PROD > Settings > API

NEXT_PUBLIC_SUPABASE_PROD_URL=https://SEU_PROJETO_PROD.supabase.co
NEXT_PUBLIC_SUPABASE_PROD_ANON_KEY=eyJhbGc...chave-anon-prod

# ⚠️ SERVER-ONLY - Jamais exponha ao cliente!
SUPABASE_PROD_SERVICE_ROLE_KEY=eyJhbGc...chave-service-prod

# ========================================
# CONFIGURAÇÃO ATIVA (alterne entre DEV e PROD)
# ========================================
# Para usar DEV locally:
NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_DEV_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_DEV_ANON_KEY}

# Para DEPLOY em produção, use as variáveis do Vercel:
# NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_PROD_URL}
# NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_PROD_ANON_KEY}

# ========================================
# JWT SECRET
# ========================================
# Gere uma nova para cada ambiente!
# Dev: pode usar qualquer string
# Prod: use `openssl rand -base64 32`

JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_use_openssl_rand_base64_32
